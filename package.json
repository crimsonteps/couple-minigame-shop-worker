{
  "name": "couple-minigame-shop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:frontend": "node scripts/build-frontend.mjs",
    "build:server": "node scripts/build-server.mjs",
    "build:charades-words": "node scripts/generate-charades-word-bank.mjs",
    "dev:frontend": "node scripts/build-frontend.mjs --watch",
    "dev:server": "tsx watch src/index.ts",
    "dev": "npm-run-all --parallel dev:frontend dev:server",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:frontend && npm run build:server && npm run typecheck",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "esbuild": "^0.25.1",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
