#!/bin/zsh
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
PID_DIR="$PROJECT_DIR/.run"
LOG_DIR="$PROJECT_DIR/.logs"
PID_FILE="$PID_DIR/dev.pid"
LOG_FILE="$LOG_DIR/dev.log"

mkdir -p "$PID_DIR" "$LOG_DIR"
cd "$PROJECT_DIR"

if ! command -v npm >/dev/null 2>&1; then
  echo "npm not found. Install Node.js first."
  exit 1
fi

if [ -f "$PID_FILE" ]; then
  OLD_PID="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [ -n "${OLD_PID:-}" ] && kill -0 "$OLD_PID" 2>/dev/null; then
    echo "Dev server is already running (PID $OLD_PID)."
    echo "Open: http://127.0.0.1:8787/"
    exit 0
  fi
  rm -f "$PID_FILE"
fi

if lsof -nP -iTCP:8787 -sTCP:LISTEN >/dev/null 2>&1; then
  echo "Port 8787 is already in use. Run ./stop first or free the port."
  exit 1
fi

if [ ! -d node_modules ]; then
  echo "node_modules not found. Run npm install manually first."
  exit 1
fi

nohup npm run dev >"$LOG_FILE" 2>&1 &
SERVER_PID=$!
echo "$SERVER_PID" > "$PID_FILE"

sleep 1

if ! kill -0 "$SERVER_PID" 2>/dev/null; then
  echo "Failed to start. Check log: $LOG_FILE"
  rm -f "$PID_FILE"
  exit 1
fi

echo "Started. PID: $SERVER_PID"
echo "Log: $LOG_FILE"
echo "Open: http://127.0.0.1:8787/"
echo "yzy: http://127.0.0.1:8787/index.html?user=yzy"
echo "wh: http://127.0.0.1:8787/index.html?user=wh"
